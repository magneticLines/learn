<mxfile host="cursor" modified="2025-12-12T00:00:00.000Z" agent="cursor" version="1.0" type="device">
  <diagram id="Page-1" name="Page-1">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="dtitle" value="红黑树删除修复流程(扩展)&#xa;核心难点: Double Black(双黑) 的消除" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="480" y="20" width="820" height="80" as="geometry" />
        </mxCell>
        <mxCell id="DNOTE" value="读图提示&#xa;- Double Black 不是“真的两种颜色”, 而是“黑高多1”的临时状态&#xa;- 修复本质: 通过兄弟节点借/还黑高&#xa;- Case A 先把 sibling 变成黑色兄弟, 再按 B/C/D 处理&#xa;- 左右分支完全镜像(旋转方向相反)" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="1320" y="20" width="320" height="220" as="geometry" />
        </mxCell>

        <!-- Main spine -->
        <mxCell id="D0" value="BST删除完成(可能用后继/前驱替换)&#xa;若删除黑节点, 可能产生“双黑”落在 x 上&#xa;x 可能是 NIL(哨兵, 视为 BLACK)" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="520" y="130" width="740" height="150" as="geometry" />
        </mxCell>
        <mxCell id="DW" value="while 条件?&#xa;(x != root) &amp;&amp; (color(x) == BLACK)" style="shape=rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="740" y="310" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="DSIDE" value="x 相对 parent 的位置?" style="shape=rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="740" y="500" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="DEND" value="结束&#xa;set x BLACK&#xa;(保证根黑, 黑高恢复)&#xa;Done" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="600" y="1740" width="580" height="130" as="geometry" />
        </mxCell>

        <!-- Left branch -->
        <mxCell id="L0" value="【左分支】x 是 parent 的左孩子&#xa;sibling = rightOf(parent)" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="40" y="690" width="560" height="120" as="geometry" />
        </mxCell>
        <mxCell id="LA" value="sibling 是 RED ?" style="shape=rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="170" y="840" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="LACT" value="Case A: sibling 红&#xa;recolor: sibling-&gt;BLACK, parent-&gt;RED&#xa;rotateLeft(parent)&#xa;(转换为 sibling 黑, 重新取 sibling)" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="40" y="1020" width="660" height="160" as="geometry" />
        </mxCell>
        <mxCell id="LB" value="sibling 黑 且两个子都是 BLACK ?" style="shape=rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="200" y="1210" width="340" height="170" as="geometry" />
        </mxCell>
        <mxCell id="LBCT" value="Case B: sibling 黑 + 两子黑&#xa;recolor: sibling-&gt;RED&#xa;x = parent (双黑上推)&#xa;继续 while" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="40" y="1410" width="660" height="160" as="geometry" />
        </mxCell>
        <mxCell id="LC" value="sibling 黑 且“外侧子”为 RED ?&#xa;(外侧= sibling 的右子)" style="shape=rhombus;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="200" y="1600" width="360" height="190" as="geometry" />
        </mxCell>
        <mxCell id="LDCT" value="Case D: 内侧红、外侧黑&#xa;(内侧= sibling 的左子)&#xa;rotateRight(sibling)&#xa;→ 转成“外侧红”再进入 Case C" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="40" y="1820" width="700" height="160" as="geometry" />
        </mxCell>
        <mxCell id="LCCT" value="Case C: 外侧红(终结态)&#xa;recolor:&#xa;- sibling.color = parent.color&#xa;- parent-&gt;BLACK&#xa;- sibling.outerChild-&gt;BLACK&#xa;rotateLeft(parent)&#xa;令 x = root (跳出循环)" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="40" y="2010" width="740" height="220" as="geometry" />
        </mxCell>

        <!-- Right branch -->
