  <diagram id="Page-1" name="Page-1">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="红黑树：概念总览&#xa;(规则 → 心智模型 → 操作工具箱)" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="420" y="20" width="660" height="80" as="geometry" />
        </mxCell>

        <mxCell id="A" value="工程动机&#xa;- AVL: 更严平衡, 写入旋转多&#xa;- RBT: 弱平衡, 写入更省&#xa;目标: 查找 O(log n), 调整成本更低" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="40" y="140" width="420" height="170" as="geometry" />
        </mxCell>
        <mxCell id="B" value="5条性质(铁律)&#xa;1. 节点红/黑&#xa;2. 根黑&#xa;3. NIL黑&#xa;4. 红节点子必黑(禁止红红相连)&#xa;5. 任一路径黑高相同" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="540" y="140" width="420" height="190" as="geometry" />
        </mxCell>
        <mxCell id="C" value="2-3-4树同构(心智模型)&#xa;- 黑=经理, 红=助理&#xa;- 红链接与黑父合并成“大节点”(2/3/4节点)&#xa;- 黑高一致 ⇔ 叶子同层" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="1040" y="140" width="420" height="170" as="geometry" />
        </mxCell>

        <mxCell id="D" value="修复工具箱&#xa;- Recolor(变色): 优先, 成本低; 常用于“叔叔红”把问题上推&#xa;- Rotate(旋转): 兜底; 结构性修复(LL/LR/RL/RR)&#xa;- 新插入默认RED: 不破坏黑高(规则5), 只可能破坏规则4" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="160" y="370" width="1040" height="210" as="geometry" />
        </mxCell>

        <mxCell id="E" value="不变量与直觉&#xa;- 规则4限制局部“红链长度”&#xa;- 规则5限制高度: 最长路径 ≤ 最短路径×2&#xa;⇒ 高度 O(log n)" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="160" y="620" width="1040" height="130" as="geometry" />
        </mxCell>

        <mxCell id="Legend" value="图例&#xa;RED/BLACK: 节点颜色&#xa;NIL: 叶子空指针哨兵(视为BLACK)&#xa;LL/LR/RL/RR: 旋转形态(见插入修复图)" style="whiteSpace=wrap;html=1;rounded=1;absoluteArcSize=1;arcSize=18;" parent="1" vertex="1">
          <mxGeometry x="1240" y="370" width="260" height="180" as="geometry" />
        </mxCell>

